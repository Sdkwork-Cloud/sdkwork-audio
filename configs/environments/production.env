# SDKWork Audio Production Environment Configuration

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUST_LOG=info

# Database
DATABASE_URL=sqlite:/app/data/audio.db
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=5

# Drive Service
DRIVE_BASE_URL=http://drive-api.sdkwork.svc.cluster.local:8081
DRIVE_API_KEY=${DRIVE_API_KEY}

# IAM Service
IAM_BASE_URL=http://iam-api.sdkwork.svc.cluster.local:8082
IAM_API_KEY=${IAM_API_KEY}

# Redis
REDIS_URL=redis://redis.sdkwork.svc.cluster.local:6379

# CORS
CORS_ALLOWED_ORIGINS=https://audio.sdkwork.com,https://app.sdkwork.com

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_REQUESTS_PER_DAY=100000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Features
ENABLE_REALTIME=true
ENABLE_VOICE_CLONING=true
ENABLE_SOUND_EFFECTS=true
