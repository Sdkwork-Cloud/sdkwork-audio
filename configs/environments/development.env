# SDKWork Audio Development Environment Configuration

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUST_LOG=debug

# Database
DATABASE_URL=sqlite:audio-dev.db
DATABASE_MAX_CONNECTIONS=5
DATABASE_MIN_CONNECTIONS=1

# Drive Service
DRIVE_BASE_URL=http://localhost:8081
DRIVE_API_KEY=dev-drive-api-key

# IAM Service
IAM_BASE_URL=http://localhost:8082
IAM_API_KEY=dev-iam-api-key

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_DAY=10000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Features
ENABLE_REALTIME=true
ENABLE_VOICE_CLONING=true
ENABLE_SOUND_EFFECTS=true
