{
  "name": "@sdkwork/audio-pc-generation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Audio and sound-effect generation workspace UI for PC surfaces.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "import": "./src/react.ts",
      "default": "./src/react.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sdkwork/generations-pc-asset-config": "workspace:*",
    "@sdkwork/generations-pc-studio": "workspace:*"
  },
  "peerDependencies": {
    "@sdkwork/ui-pc-react": "workspace:*",
    "react": ">=18.2.0 <20.0.0",
    "react-dom": ">=18.2.0 <20.0.0",
    "react-i18next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "@sdkwork/ui-pc-react": {
      "optional": true
    }
  },
  "sdkwork": {
    "workspace": "sdkwork-audio",
    "architecture": "pc",
    "domain": "content",
    "capability": "generation",
    "status": "ready"
  }
}
